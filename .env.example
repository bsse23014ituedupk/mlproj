# =============================================================================
# Water Potability Classifier — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=water_potability_v1
MLFLOW_MODEL_NAME=water_potability_classifier

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Data Paths
RAW_DATA_PATH=data/raw/water_potability.csv
PROCESSED_DATA_PATH=data/processed/
SPLITS_DATA_PATH=data/splits/

# Model Configuration
RANDOM_SEED=42
TEST_SIZE=0.20
VAL_SIZE=0.10

# Logging
LOG_LEVEL=INFO
